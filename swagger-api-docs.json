    "/generateConditionalNode": {
      "post": {
        "tags": ["节点操作"],
        "summary": "条件判断节点-生成拆分后节点",
        "description": "为条件判断节点生成拆分后的子节点",
        "operationId": "generateConditionalNode",
        "consumes": ["application/json"],
        "produces": ["application/json"],
        "parameters": [
          {
            "name": "workFlowId",
            "in": "body",
            "description": "工作流ID",
            "required": true,
            "schema": {
              "type": "number"
            }
          },
          {
            "name": "nodeId",
            "in": "body",
            "description": "节点ID",
            "required": true,
            "schema": {
              "type": "number"
            }
          },
          {
            "name": "name",
            "in": "body",
            "description": "节点名称",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "processX",
            "in": "body",
            "description": "X坐标",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "processY",
            "in": "body",
            "description": "Y坐标",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "remark",
            "in": "body",
            "description": "备注",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "conditions",
            "in": "body",
            "description": "子节点名称列表",
            "required": true,
            "schema": {
              "type": "array",
              "items": {
                "type": "object"
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "schema": {
              "$ref": "#/definitions/ResponseResult"
            }
          }
        }
      }
    },
