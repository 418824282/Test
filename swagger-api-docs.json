{
  "swagger": "2.0",
  "info": {
    "title": "AI工作流接口文档",
    "description": "AiFlowController 接口文档 - 包含智能体管理、工作流管理、节点操作等接口",
    "version": "1.0.0",
    "contact": {
      "name": "开发团队"
    }
  },
  "basePath": "/aiworkflow",
  "tags": [
    {
      "name": "全局配置",
      "description": "全局配置相关接口"
    },
    {
      "name": "智能体管理",
      "description": "智能体的增删改查操作"
    },
    {
      "name": "工作流管理",
      "description": "工作流的增删改查、状态管理"
    },
    {
      "name": "节点操作",
      "description": "节点的添加、修改、删除、条件设置"
    }
  ],
  "paths": {
    "/globalConfiguration": {
      "post": {
        "tags": ["全局配置"],
        "summary": "获取全局配置信息",
        "description": "获取AI工作流全局配置信息",
        "operationId": "globalConfiguration",
        "consumes": ["application/json"],
        "produces": ["application/json"],
        "responses": {
          "200": {
            "description": "成功",
            "schema": {
              "$ref": "#/definitions/ResponseResult"
            }
          }
        }
      }
    },
    "/openOrCloseGlobalConfig": {
      "post": {
        "tags": ["全局配置"],
        "summary": "开启/关闭全局配置",
        "description": "开启或关闭AI工作流全局配置",
        "operationId": "openOrCloseGlobalConfig",
        "consumes": ["application/json"],
        "produces": ["application/json"],
        "parameters": [
          {
            "name": "isOpen",
            "in": "body",
            "description": "是否开启 (0-关闭, 1-开启)",
            "required": true,
            "schema": {
              "type": "number"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "schema": {
              "$ref": "#/definitions/ResponseResult"
            }
          }
        }
      }
    },
